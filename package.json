{
  "name": "port-guard",
  "version": "0.1.0",
  "description": "CLI tool to manage, monitor, and control processes running on ports",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "port-guard": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node scripts/build.cjs",
    "dev": "node --watch src/cli/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "port",
    "monitor",
    "process",
    "kill",
    "devtools",
    "terminal",
