{
  "name": "port-guard",
  "version": "0.1.0",
  "description": "Manage, monitor, and control processes running on ports",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "port-guard": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "node scripts/build.cjs",
    "dev": "node --watch src/cli/index.js",
    "prepublishOnly": "npm run build",
    "test": "node --test tests/*.test.js"
  },
  "keywords": ["port", "process", "monitor", "kill", "devtools", "cli"],
  "author": "Deepak Ashok Karai",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
