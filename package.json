  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devin00100/port-guard.git"
  },
  "bugs": {
    "url": "https://github.com/devin00100/port-guard/issues"
  },
  "homepage": "https://github.com/devin00100/port-guard#readme"
